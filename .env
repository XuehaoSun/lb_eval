# Copy this file to .env, fill MINIMAX_API_KEY, then run ./run.sh

IMAGE_NAME=cuda-openclaw:local
CONTAINER_NAME=cuda-openclaw-test

# ── Required: fill your MiniMax API key ───────────────────────────────────────
MINIMAX_API_KEY=

# ── Auto-Quant / Auto-Eval defaults ──────────────────────────────────────────
MODEL_ID=Qwen/Qwen3-0.6B
SCHEME=W4A16
METHOD=RTN
EXPORT_FORMAT=auto_round
DEVICE=cuda
DEVICE_INDEX=0
OUTPUT_DIR=/root/.openclaw/workspace/quantized
TIMEOUT=36000

# ── Intel proxy ──────────────────────────────────────────────────────────────
HTTP_PROXY=
HTTPS_PROXY=

